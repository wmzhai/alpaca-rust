{
  "name": "alpaca-rust-workspace",
  "private": true,
  "scripts": {
    "test:packages": "pnpm --filter @alpaca/time test && pnpm --filter @alpaca/option test",
    "typecheck:packages": "pnpm --filter @alpaca/time typecheck && pnpm --filter @alpaca/option typecheck",
    "build:website": "pnpm --dir website build"
  },
  "devDependencies": {
    "tsx": "4.20.6"
  },
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "packages/*",
    "website"
  ]
}
