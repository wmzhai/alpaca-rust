#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
from pathlib import Path


ROOT = Path(__file__).resolve().parents[2]
DOCS_GENERATED = ROOT / "docs" / "generated"
CRATE_ORDER = [
    "alpaca-core",
    "alpaca-rest-http",
    "alpaca-data",
    "alpaca-trade",
    "alpaca-mock",
    "alpaca-time",
    "alpaca-option",
    "alpaca-facade",
]
CRATE_LAYERS = {
    "alpaca-core": "foundation",
    "alpaca-rest-http": "foundation",
    "alpaca-data": "foundation",
    "alpaca-trade": "foundation",
    "alpaca-mock": "foundation",
    "alpaca-time": "semantic",
    "alpaca-option": "semantic",
    "alpaca-facade": "facade",
}
CRATE_PATHS = {
    "alpaca-core": "crates/alpaca-core",
    "alpaca-rest-http": "crates/alpaca-http",
    "alpaca-data": "crates/alpaca-data",
    "alpaca-trade": "crates/alpaca-trade",
    "alpaca-mock": "crates/alpaca-mock",
    "alpaca-time": "crates/alpaca-time",
    "alpaca-option": "crates/alpaca-option",
    "alpaca-facade": "crates/alpaca-facade",
}


def main() -> int:
    DOCS_GENERATED.mkdir(parents=True, exist_ok=True)
    metadata = json.loads(
        subprocess.run(
            ["cargo", "metadata", "--format-version", "1", "--no-deps"],
            cwd=ROOT,
            check=True,
            capture_output=True,
            text=True,
        ).stdout
    )

    packages_by_name = {pkg["name"]: pkg for pkg in metadata["packages"]}
    packages = [
        {
            "name": name,
            "path": CRATE_PATHS[name],
            "layer": CRATE_LAYERS[name],
            "version": packages_by_name[name]["version"],
            "authors": packages_by_name[name].get("authors", []),
            "description": packages_by_name[name].get("description"),
            "documentation": packages_by_name[name].get("documentation"),
            "homepage": packages_by_name[name].get("homepage"),
        }
        for name in CRATE_ORDER
        if name in packages_by_name
    ]

    (DOCS_GENERATED / "api-index.json").write_text(
        json.dumps({"workspace": "alpaca-rust", "packages": packages}, indent=2) + "\n"
    )
    (DOCS_GENERATED / "project-structure.json").write_text(
        json.dumps(
            {
                "packages": {
                    pkg["name"]: {
                        "path": pkg["path"],
                        "layer": pkg["layer"],
                        "description": pkg.get("description"),
                    }
                    for pkg in packages
                }
            },
            indent=2,
        )
        + "\n"
    )
    (DOCS_GENERATED / "sidebar-schema.json").write_text(
        json.dumps(
            {
                "docs": [
                    "index",
                    "getting-started",
                    "authentication",
                    "project-structure",
                    "reference/index",
                    "reference/alpaca-core",
                    "reference/alpaca-rest-http",
                    "reference/alpaca-data",
                    "reference/alpaca-trade",
                    "reference/alpaca-mock",
                    "reference/alpaca-time",
                    "reference/alpaca-option",
                    "reference/alpaca-facade",
                    "api-coverage/market-data",
                    "api-coverage/trading",
                    "trade-mainline",
                    "release-checklist",
                ]
            },
            indent=2,
        )
        + "\n"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
