def request_model(
    file: str,
    model_type: str,
    location: str,
    *,
    prefix: str | None = None,
    field_map: dict[str, str] | None = None,
) -> dict[str, Any]:
    return {
        "file": file,
        "type": model_type,
        "location": location,
        "prefix": prefix,
        "field_map": field_map or {},
    }


def argument(name: str, location: str, rust_name: str | None = None) -> dict[str, str]:
    return {
        "contract_path": name,
        "location": location,
        "rust_argument": rust_name or name,
    }


def source(
    resource: str,
    method: str,
    operation_label: str,
    helper: str,
    api_type: str,
    model_type: str,
    *,
    wire_type: str | None = None,
    model_resource: str | None = None,
    model_file: str = "model.rs",
    request_models: list[dict[str, Any]] | None = None,
    arguments: list[dict[str, str]] | None = None,
    success_status: int | str = 200,
) -> dict[str, Any]:
    model_resource = model_resource or resource
    return {
        "client_file": f"crates/alpaca-trade/src/{resource}/client.rs",
        "client_method": method,
        "operation_label": operation_label,
        "transport": {
            "helper": helper,
            "wire_type": wire_type,
            "success_status": success_status,
        },
        "request_models": request_models or [],
        "argument_bindings": arguments or [],
        "response_model": {
            "api_type": api_type,
            "file": f"crates/{model_resource}/src/{model_file}"
            if model_resource == "alpaca-http"
            else f"crates/alpaca-trade/src/{model_resource}/{model_file}",
            "type": model_type,
        },
    }


