def _pending_reason(operation_id: str) -> str:
    if operation_id == "optionDoNotExercise":
        return "Paper requires an expiration-day long option position; raw Paper and mock validation succeeded, but the corrected liquid-contract Paper scenario still requires a clean account and complete cleanup"
    raise ValueError(f"missing pending reason for {operation_id}")


def _handler_file(handler: str) -> str:
    if handler.startswith("account_"):
        resource = "account"
    elif handler.startswith("activities_"):
        resource = "activities"
    elif handler.startswith("portfolio_history_"):
        resource = "portfolio_history"
    elif handler.startswith("options_contracts_"):
        resource = "options_contracts"
    elif handler.startswith("watchlists_"):
        resource = "watchlists"
    elif handler.startswith("positions_"):
        resource = "positions"
    elif handler.startswith("orders_"):
        resource = "orders"
    elif handler.startswith("assets_"):
        resource = "assets"
    elif handler.startswith("calendar_"):
        resource = "calendar"
    elif handler.startswith("clock_"):
        resource = "clock"
    else:
        raise ValueError(f"unclassified mock handler: {handler}")
    return f"crates/alpaca-mock/src/handlers/{resource}.rs"


def _request_contract_keys(contract: dict[str, Any]) -> set[tuple[str, str]]:
    keys = {
        (parameter["in"], parameter["name"]) for parameter in contract["parameters"]
    }
    body = contract.get("request_body")
    if body is not None:
        keys.update(("body", field["path"]) for field in body.get("fields", []))
    return keys


def _expand_request_bindings(
    operation_id: str, contract: dict[str, Any], source_binding: dict[str, Any]
) -> None:
    exception_keys = {
        (exception["location"], exception["path"])
        for exception in CONTRACT_EXCEPTIONS.get(operation_id, [])
    }
    bound: set[tuple[str, str]] = set()
    for binding in source_binding["argument_bindings"]:
        bound.add((binding["location"], binding["contract_path"]))

    for model in source_binding["request_models"]:
        model["field_bindings"] = []

    for location, contract_path in sorted(_request_contract_keys(contract)):
        if (location, contract_path) in exception_keys:
            continue
        if (location, contract_path) in bound:
            continue
        candidates = [
            model
            for model in source_binding["request_models"]
            if model["location"] == location
            and (
                model["prefix"] is None
                or contract_path.startswith(f"{model['prefix']}.")
                or contract_path.startswith(f"{model['prefix']}[]")
            )
        ]
        if not candidates:
            continue
        candidates.sort(key=lambda model: len(model["prefix"] or ""), reverse=True)
        selected = candidates[0]
        prefix = selected["prefix"]
        if prefix is None and ("." in contract_path or "[]" in contract_path):
            continue
        relative_path = contract_path
        if prefix is not None:
            relative_path = (
                relative_path.removeprefix(prefix).removeprefix("[]").removeprefix(".")
            )
        rust_field = relative_path.split(".")[-1].removesuffix("[]")
        rust_field = selected["field_map"].get(rust_field, rust_field)
        selected["field_bindings"].append(
            {
                "contract_path": contract_path,
                "rust_field": rust_field,
            }
        )
        bound.add((location, contract_path))

    for model in source_binding["request_models"]:
        model.pop("prefix")
        model.pop("field_map")
        model["field_bindings"].sort(key=lambda binding: binding["contract_path"])

    missing = _request_contract_keys(contract) - bound - exception_keys
    if missing:
        rendered = ", ".join(f"{location}:{path}" for location, path in sorted(missing))
        raise ValueError(
            f"missing request source bindings for {operation_id}: {rendered}"
        )


def _excluded_reason(operation: dict[str, Any]) -> str:
    tag = operation["tag"]
    path = operation["path"]
    if path.startswith("/v2/assets/fixed_income/"):
        return (
            "Fixed-income asset discovery is outside the adopted equities/options scope"
        )
    if tag == "Corporate Actions":
        return "Corporate-action announcement coverage is owned by alpaca-data"
    if tag == "Events":
        return "SSE and event-stream APIs are outside the HTTP REST scope"
    if tag == "Locates":
        return "Locates are explicitly deferred from the adopted Trading API surface"
    if tag == "Tokenization":
        return "Tokenization is outside the adopted Trading API surface"
    if tag.startswith("Crypto"):
        return "Crypto and crypto-perpetual APIs are outside the adopted asset scope"
    return "Operation is outside the explicitly adopted Trading API surface"


def build_manifest(
    document: dict[str, Any], payload: bytes, generated_at: str
) -> dict[str, Any]:
    official_operations = canonical_operation_map(document)
    missing_bindings = set(ADOPTED_OPERATION_IDS) - set(SOURCE_BINDINGS)
    extra_bindings = set(SOURCE_BINDINGS) - set(ADOPTED_OPERATION_IDS)
    if missing_bindings or extra_bindings:
        raise ValueError(
            f"source binding inventory mismatch: missing={sorted(missing_bindings)} extra={sorted(extra_bindings)}"
        )

    mirror_layer: list[dict[str, Any]] = []
    for operation_id in ADOPTED_OPERATION_IDS:
        canonical = official_operations.get(operation_id)
        if canonical is None:
            raise ValueError(
                f"adopted operation missing from canonical OpenAPI: {operation_id}"
            )
        source_binding = json.loads(json.dumps(SOURCE_BINDINGS[operation_id]))
        _expand_request_bindings(operation_id, canonical["contract"], source_binding)
        pending = operation_id in PENDING_OPERATION_IDS
        source_binding["status"] = (
            "contract_bound_pending_validation" if pending else "contract_bound"
        )

        handler = MOCK_HANDLERS[operation_id]
        mock_binding = {
            "status": (
                "implementation_ready_pending_validation"
                if pending
                else "network_validated"
            ),
            "route_file": "crates/alpaca-mock/src/app.rs",
            "route_method": canonical["method"],
            "handler_file": _handler_file(handler),
            "handler": handler,
        }
        if pending:
            consumer_binding = {
                "status": "scenario_ready_pending_validation",
                "scenario_file": "crates/alpaca-trade/tests/trading_contract_api.rs",
                "scenario": PENDING_SCENARIOS[operation_id],
            }
            validation = {
                "status": "pending_market_open",
                "verified_targets": [],
                "required_targets": ["paper", "mock"],
                "reason": _pending_reason(operation_id),
            }
        else:
            scenario = SCENARIOS[operation_id]
            consumer_binding = {
                "status": "paper_and_mock_validated",
                "scenario_file": "crates/alpaca-trade/tests/trading_contract_api.rs",
                "scenario": scenario,
            }
            validation = {
                "status": "closed",
                "verified_targets": ["paper", "mock"],
                "required_targets": ["paper", "mock"],
            }

        entry = {
            **canonical,
            "source_binding": source_binding,
            "mock_binding": mock_binding,
            "consumer_binding": consumer_binding,
            "validation": validation,
        }
        if operation_id in CONTRACT_EXCEPTIONS:
            entry["contract_exceptions"] = CONTRACT_EXCEPTIONS[operation_id]
        if operation_id in OBSERVED_DEVIATIONS:
            entry["observed_contract_deviations"] = OBSERVED_DEVIATIONS[operation_id]
        mirror_layer.append(entry)

    adopted = set(ADOPTED_OPERATION_IDS)
    excluded_operations = [
        {
            "operation_id": operation_id,
            "tag": operation["tag"],
            "method": operation["method"],
            "path": operation["path"],
            "status": "explicitly_excluded",
            "reason": _excluded_reason(operation),
        }
        for operation_id, operation in official_operations.items()
        if operation_id not in adopted
    ]
    excluded_operations.sort(
        key=lambda entry: (entry["tag"], entry["path"], entry["method"])
    )
    adopted_tags = {entry["tag"] for entry in mirror_layer}
    excluded_tags = sorted(
        {entry["tag"] for entry in excluded_operations} - adopted_tags
    )

    return {
        "manifest_version": 2,
        "generated_at": generated_at,
        "scope": {
            "api": "trading-http-rest",
            "included_asset_scope": "US equities and options",
            "excluded_scopes": [
                "broker",
                "corporate_actions",
                "crypto",
                "events_sse",
                "fix",
                "fixed_income",
                "locates",
                "stream",
                "tokenization",
                "websocket",
            ],
        },
        "official": {
            "title": document.get("info", {}).get("title"),
            "reference_root": "https://docs.alpaca.markets/reference/api-references",
            "openapi_url": CANONICAL_OPENAPI_URL,
            "fetched_on": generated_at,
            "openapi_version": document.get("openapi"),
            "api_version": document.get("info", {}).get("version"),
            "sha256": sha256(payload),
            "total_operations": operation_count(document),
        },
        "local": {
            "crate": "alpaca-trade",
            "mock_crate": "alpaca-mock",
            "network_contract_scenario": "crates/alpaca-trade/tests/trading_contract_api.rs",
            "adopted_tags": sorted(adopted_tags),
        },
        "summary": {
            "official_total_operations": operation_count(document),
            "adopted_operations": len(mirror_layer),
            "closed_operations": sum(
                entry["validation"]["status"] == "closed" for entry in mirror_layer
            ),
            "pending_operations": sum(
                entry["validation"]["status"] != "closed" for entry in mirror_layer
            ),
            "explicitly_excluded_operations": len(excluded_operations),
        },
        "contract_binding_policy": {
            "canonical_contract": "Every adopted row stores operationId, method/path, parameters, request body, response status/body, required/nullability, and array item/minItems/maxItems constraints from the pinned OpenAPI bytes.",
            "source": "Every row binds and audits the actual client method block, canonical operation label, strict transport helper/status, all canonical request paths except explicit field exclusions, and the public response model declaration.",
            "mock": "Every row binds an actual TCP server route and handler; closed rows additionally require successful shared Paper/mock network scenario evidence.",
            "pending": "Pending rows may have contract-bound source, mock, and compiled network scenarios, but retain empty verified targets and are never counted as closed until the same scenario succeeds against Paper and mock.",
        },
        "mirror_layer": mirror_layer,
        "excluded_families": [
            {"tag": tag, "status": "explicitly_excluded"} for tag in excluded_tags
        ],
        "excluded_operations": excluded_operations,
    }


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--openapi", default=CANONICAL_OPENAPI_URL)
    parser.add_argument("--output", type=pathlib.Path, default=DEFAULT_OUTPUT)
    parser.add_argument(
        "--generated-at", default=dt.datetime.now(dt.timezone.utc).date().isoformat()
    )
    args = parser.parse_args()

    document, payload = load_openapi(args.openapi)
    manifest = build_manifest(document, payload, args.generated_at)
    args.output.write_text(json.dumps(manifest, indent=2, ensure_ascii=False) + "\n")
    print(
        f"wrote {args.output}: official={manifest['summary']['official_total_operations']} "
        f"adopted={manifest['summary']['adopted_operations']} "
        f"closed={manifest['summary']['closed_operations']} "
        f"pending={manifest['summary']['pending_operations']}"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
